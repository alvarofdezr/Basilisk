# ============================================================
# Basilisk EDR — Environment Variables Template
# Copy to .env and fill in real values.
# ============================================================

# ── Required — server will not start without these ───────────────────────────

# Argon2id hash of your admin password.
# Generate: python -c "from basilisk.core.security import hash_password; print(hash_password('your_password'))"
BASILISK_ADMIN_PASSWORD_HASH=

# Random 32+ character session key.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BASILISK_SERVER_SECRET_KEY=

# Shared token agents send in the X-Agent-Token HTTP header.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BASILISK_AGENT_TOKEN=

# ── Optional ─────────────────────────────────────────────────────────────────

# Admin username (default: admin)
# BASILISK_ADMIN_USER=admin

# C2 server URL (default: https://localhost:8443)
# BASILISK_C2_URL=https://localhost:8443

# VirusTotal API v3 key for hash reputation lookups
# BASILISK_VIRUSTOTAL_API_KEY=

# Telegram bot for alert notifications
# BASILISK_TELEGRAM_TOKEN=
# BASILISK_TELEGRAM_CHAT_ID=

# ── Integration tests only (never in production) ──────────────────────────────
# BASILISK_TEST_URL=https://localhost:8443
# BASILISK_TEST_USER=admin
# BASILISK_TEST_PASS=
# BASILISK_TEST_AGENT_ID=
